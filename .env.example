# Environment Variables Template
# Copy this file to .env and add your actual API keys
# WARNING: Never commit the .env file to version control!

# ============ LLM Provider Configuration ============

# OpenAI Configuration (Required if using OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# HuggingFace Configuration (Optional)
HUGGINGFACE_API_KEY=hf_your-huggingface-token-here
HUGGINGFACE_REPO_ID=mistralai/Mistral-7B-Instruct-v0.1

# Ollama Configuration (Optional, for local LLM)
# Leave blank if not using local LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Default Provider
# Options: "openai", "huggingface", "ollama"
DEFAULT_PROVIDER=openai

# ============ Streamlit Settings ============

STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=true

# ============ PDF Processing Settings ============

MAX_PDF_SIZE_MB=20
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# Embedding Model for semantic search
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============ Application Settings ============

APP_NAME=Chat with PDF
DEBUG=false
LOG_LEVEL=INFO
